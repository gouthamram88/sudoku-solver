#!/usr/bin/env python3
# Sudoku solver: read 9 lines of digits (1-9) with 0 or . for blanks, then print solution.

from sys import stdin, exit

def parse_input():
    lines = []
    for line in stdin:
        s = line.strip()
        if s:
            lines.append(s)
        if len(lines) >= 9:
            break
    if len(lines) < 9:
        print("Provide 9 non-empty lines representing the puzzle.")
        exit(1)
    grid = []
    for r in range(9):
        row = []
        for ch in lines[r]:
            if ch in "0.":
                row.append(0)
            elif ch.isdigit():
                row.append(int(ch))
            if len(row) == 9:
                break
        if len(row) != 9:
            print("Each line must contain at least 9 characters (digits or . / 0).")
            exit(1)
        grid.append(row)
    return grid

def print_grid(g):
    for r in range(9):
        print("".join(str(n) if n!=0 else "." for n in g[r]))

def candidates(grid, r, c):
    if grid[r][c] != 0:
        return set()
    used = set(grid[r])  # row
    used |= {grid[i][c] for i in range(9)}  # col
    br, bc = (r//3)*3, (c//3)*3
    used |= {grid[i][j] for i in range(br, br+3) for j in range(bc, bc+3)}
    return set(range(1,10)) - used

def find_empty_cells(grid):
    return [(r,c) for r in range(9) for c in range(9) if grid[r][c]==0]

def solve(grid):
    empties = find_empty_cells(grid)
    # backtracking with MRV heuristic
    def backtrack():
        if not empties:
            return True
        # choose empty with fewest candidates
        best_idx = -1
        best_cands = None
        for i, (r,c) in enumerate(empties):
            if grid[r][c] != 0:
                continue
            cand = candidates(grid, r, c)
            if not cand:
                return False
            if best_cands is None or len(cand) < len(best_cands):
                best_cands = cand
                best_idx = i
                if len(best_cands) == 1:
                    break
        r,c = empties.pop(best_idx)
        for val in sorted(best_cands):
            grid[r][c] = val
            if backtrack():
                return True
            grid[r][c] = 0
        empties.insert(best_idx, (r,c))
        return False
    return backtrack()

if __name__ == "__main__":
    grid = parse_input()
    if solve(grid):
        print_grid(grid)
    else:
        print("No solution")